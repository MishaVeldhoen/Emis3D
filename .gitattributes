# Normalize all Python and text files to LF line endings in the repository.
# Developers on Windows will still get CRLF in their working tree if
# core.autocrlf=true is set in their git config, but the repo stays clean.

* text=auto

*.py    text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.toml  text eol=lf
*.cfg   text eol=lf
*.ini   text eol=lf
*.sh    text eol=lf

# Binary files — never rewrite
*.png   binary
*.jpg   binary
*.stl   binary
*.h5    binary
*.hdf5  binary
*.dill  binary
